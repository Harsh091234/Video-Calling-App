{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./server/dist",
    "rootDir": "./server/src",
    "declaration": true,
    "sourceMap": false,
    "removeComments": true,
    "types": ["node"]
  },

  "include": ["server/src/**/*"],
  "exclude": ["node_modules", "server/dist"]
}
